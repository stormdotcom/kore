    "dev": "tsup --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "node-pty": "^1.1.0-beta23",
    "strip-ansi": "^7.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "rimraf": "^5.0.10",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
