{
  "name": "kore-monorepo",
  "private": true,
  "main": "dist-pkg/index.cjs",
  "bin": "dist-pkg/index.cjs",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter kore-cli dev",
    "start": "pnpm --filter kore-cli start",
    "launch": "node -e \"require('child_process').execSync(process.platform === 'win32' ? 'powershell .\\\\launch.ps1' : './launch.sh', {stdio: 'inherit'})\"",
    "create:shortcut": "node -e \"require('child_process').execSync(process.platform === 'win32' ? 'powershell .\\\\scripts\\\\create-windows-shortcut.ps1' : './scripts/install-linux-launcher.sh', {stdio: 'inherit'})\"",
    "clean": "pnpm -r clean",
    "typecheck": "pnpm -r typecheck",
    "package": "pnpm run package:prepare && pnpm run package:build",
    "package:prepare": "pnpm build && pnpm --filter kore-cli exec tsup --config tsup.config.pkg.ts",
    "package:build": "pkg . --targets node18-win-x64,node18-linux-x64 --output dist-pkg/kore --compress Brotli",
    "package:windows": "pnpm run package:prepare && pkg . --targets node18-win-x64 --output dist-pkg/kore-win.exe --compress Brotli",
    "package:linux": "pnpm run package:prepare && pkg . --targets node18-linux-x64 --output dist-pkg/kore-linux --compress Brotli"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "pkg": {
    "assets": [
      "node_modules/blessed/usr/**"
    ],
    "outputPath": "dist-pkg"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.14.1",
    "esbuild": "^0.27.3"
  },
  "packageManager": "pnpm@10.8.1+sha512.c50088ba998c67b8ca8c99df8a5e02fd2ae2e2b29aaf238feaa9e124248d3f48f9fb6db2424949ff901cffbb5e0f0cc1ad6aedb602cd29450751d11c35023677"
}
